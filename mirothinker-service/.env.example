# MiroThinker Service - Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=MiroThinker Online Service
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=1

# DashScope LLM (Required)
DASHSCOPE_API_KEY=your_dashscope_api_key

# Legacy API Keys (Optional, for backward compatibility)
SERPER_API_KEY=
JINA_API_KEY=

# Model Configuration
DEFAULT_MODEL=qwen-plus
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TURNS=200
DEFAULT_CONTEXT_KEEP=5

# Concurrency
MAX_CONCURRENT_TASKS=2

# CORS
CORS_ORIGINS=["*"]

# Data Directories
DATA_DIR=data
TRACES_DIR=data/traces
LOGS_DIR=data/logs
CACHE_DIR=data/cache

# Frontend
FRONTEND_DIR=frontend
